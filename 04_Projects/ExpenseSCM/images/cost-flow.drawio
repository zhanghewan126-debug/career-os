        <mxCell id="ce2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.15;" edge="1" parent="1" source="receipt" target="calc">
          <mxGeometry relative="1" as="geometry">
