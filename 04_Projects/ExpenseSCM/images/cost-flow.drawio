        <mxCell id="m4" value="回写本期&#10;出库事务成本" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=9.5;" vertex="1" parent="1">
          <mxGeometry x="630" y="460" width="170" height="50" as="geometry" />
