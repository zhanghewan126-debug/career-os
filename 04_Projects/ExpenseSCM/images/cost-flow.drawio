<mxfile host="app.diagrams.net" modified="2026-07-08T00:00:00.000Z" agent="drawio" version="24.0.0" type="device">
  <diagram id="expensescm-cost-flow" name="Cost Flow">
    <mxGraphModel dx="1300" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1240" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="ExpenseSCM Cost Flow｜月度加权平均成本核算（ITEM_PERIOD_COST）" style="text;html=1;fontSize=18;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="10" width="760" height="30" as="geometry" />
        </mxCell>

        <mxCell id="begin" value="期初 Begin&#10;begin_qty / begin_amount&#10;＝上期期末结转" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10.5;" vertex="1" parent="1">
          <mxGeometry x="50" y="120" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="receipt" value="本期入库 ＋&#10;Σ 入库事务金额（按 PO 单价）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10.5;" vertex="1" parent="1">
          <mxGeometry x="300" y="60" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="return" value="本期验退 －&#10;Σ 验退事务金额（原入库成本冲减）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10.5;" vertex="1" parent="1">
          <mxGeometry x="300" y="150" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="calc" value="月结计算 unit_cost（加权平均）&#10;&#10;unit_cost ＝&#10;（期初成本×期初数量＋本期入库金额－本期验退金额）&#10;÷（期初数量＋本期入库数量－本期验退数量）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10.5;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="590" y="100" width="300" height="120" as="geometry" />
        </mxCell>
        <mxCell id="end" value="期末 End&#10;end_qty / end_amount&#10;closed_flag 期间关闭" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10.5;" vertex="1" parent="1">
          <mxGeometry x="990" y="120" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="issue" value="领用出库 Issue&#10;按当期 unit_cost 计价 → issue_amount&#10;（不参与单位成本重算）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10.5;" vertex="1" parent="1">
          <mxGeometry x="590" y="300" width="300" height="90" as="geometry" />
        </mxCell>

        <mxCell id="ce1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.33;" edge="1" parent="1" source="begin" target="calc">
          <mxGeometry relative="1" as="geometry">
