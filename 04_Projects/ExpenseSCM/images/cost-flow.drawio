        <mxCell id="ce3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.7;" edge="1" parent="1" source="return" target="calc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce4" value="期末滚动结转" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="calc" target="end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce5" value="unit_cost" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;fontSize=10;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="calc" target="issue">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce6" value="结转为下一期间期初" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;dashed=1;fontSize=10;exitX=0.5;exitY=1;entryX=0.5;entryY=1;" edge="1" parent="1" source="end" target="begin">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1090" y="250" />
              <mxPoint x="140" y="250" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- month-end close strip -->
        <mxCell id="zoneM" value="月结流程 Month-End Close" style="rounded=1;dashed=1;fillColor=none;strokeColor=#9673a6;verticalAlign=top;align=left;fontStyle=1;fontColor=#9673a6;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="1160" height="120" as="geometry" />
        </mxCell>
        <mxCell id="m1" value="校验本期事务&#10;全部过账" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=9.5;" vertex="1" parent="1">
          <mxGeometry x="60" y="460" width="170" height="50" as="geometry" />
