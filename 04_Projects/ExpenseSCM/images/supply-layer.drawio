<mxfile host="app.diagrams.net" modified="2026-07-08T00:00:00.000Z" agent="drawio" version="24.0.0" type="device">
  <diagram id="expensescm-supply-layer" name="Supply Layer">
    <mxGraphModel dx="1300" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1240" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="ExpenseSCM Supply Layer｜七层供需模型（EXP_MTL_SUPPLY）" style="text;html=1;fontSize=18;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="10" width="720" height="30" as="geometry" />
        </mxCell>

        <!-- In-transit group -->
        <mxCell id="transit" value="在途供应 In-Transit Supply" style="rounded=1;dashed=1;fillColor=none;strokeColor=#999999;verticalAlign=top;align=left;fontStyle=1;fontColor=#999999;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="55" y="85" width="830" height="150" as="geometry" />
        </mxCell>

        <!-- 7 layers -->
        <mxCell id="l-pr" value="PR&#10;已请购未转采购" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2e6;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="120" width="145" height="90" as="geometry" />
        </mxCell>
        <mxCell id="l-ppr" value="PPR&#10;采购准备中" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd9;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="120" width="145" height="90" as="geometry" />
        </mxCell>
        <mxCell id="l-po" value="PO&#10;已下单未到货（在途）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="410" y="120" width="145" height="90" as="geometry" />
        </mxCell>
        <mxCell id="l-rcv" value="RECEIVING&#10;已到货检验中" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffdfbf;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="580" y="120" width="145" height="90" as="geometry" />
        </mxCell>
        <mxCell id="l-acc" value="ACCEPT&#10;检验合格待入库" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd9b3;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="750" y="120" width="145" height="90" as="geometry" />
        </mxCell>
        <mxCell id="l-oh" value="ONHAND&#10;在库可用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcc99;strokeColor=#b36b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="120" width="145" height="90" as="geometry" />
        </mxCell>
        <mxCell id="l-ret" value="RETURN&#10;验退处理中" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="290" width="145" height="80" as="geometry" />
        </mxCell>

        <!-- terminators -->
        <mxCell id="t-issue" value="领用出库&#10;（消耗，离开供应层）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1105" y="135" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="t-rtv" value="退回供应商&#10;（冲减库存与成本）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1105" y="300" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- flow edges -->
        <mxCell id="s0" value="请购单核准" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;fontSize=9;entryX=0;entryY=0.5;" edge="1" parent="1" target="l-pr">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="20" y="165" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s1" value="转采购准备" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="l-pr" target="l-ppr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="PO 核准" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="l-ppr" target="l-po">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="供应商送货" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="l-po" target="l-rcv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="检验合格" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="l-rcv" target="l-acc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="入库过账" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="l-acc" target="l-oh">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="领用核准发料" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="l-oh" target="t-issue">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="验退单（品质不合格）" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;fontSize=9;strokeColor=#b85450;fontColor=#b85450;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="l-oh" target="l-ret">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s8" value="退厂完成" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="l-ret" target="t-rtv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- demand layer -->
        <mxCell id="demand" value="Demand Layer（EXP_MTL_DEMAND）&#10;已核准未发料的开放需求（领用预约占用可用量）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="420" width="560" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ed1" value="供需匹配" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=open;startArrow=open;dashed=1;fontSize=9;exitX=0.8;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="demand" target="l-oh">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="518" y="395" />
              <mxPoint x="992" y="395" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- formula -->
        <mxCell id="formula" value="可用量 ＝ ONHAND ＋ 在途供应（PR＋PPR＋PO＋RECEIVING＋ACCEPT）－ 开放需求（Demand）&#10;&#10;请购与领用校验均基于可用量，从数据模型层面抑制重复采购与库存超发" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="670" y="420" width="555" height="80" as="geometry" />
        </mxCell>

        <mxCell id="note" value="数量守恒：业务每推进一个节点，数量从上一层扣减、在下一层增加（supply_type_code 流转），整条供应链数量可交叉对账。" style="text;html=1;fontSize=9.5;fontColor=#666666;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="530" width="800" height="20" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
